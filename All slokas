const kb = window.FULL_KB;
document.getElementById('stats').textContent = `कुल ${kb.length} श्लोक लोड • खोज शुरू करें`;

function search(){
 const q = document.getElementById('q').value.trim().toLowerCase();
 if(!q){document.getElementById('results').innerHTML='<p style="text-align:center;color:#999;padding:20px">ऊपर लिखें और खोजें</p>';return}
 const results = kb.filter(i => 
   i.condition_hindi.toLowerCase().includes(q) || 
   i.hindi.toLowerCase().includes(q) ||
   i.sanskrit.includes(q)
 ).slice(0,20);
 
 document.getElementById('stats').textContent = `${results.length} परिणाम`;
 document.getElementById('results').innerHTML = results.length ? 
   results.map((r,i) => `
   <div class="card">
     <div style="display:flex;justify-content:space-between">
       <h3 style="color:#8B0000;margin:0 0 6px 0;font-size:16px">${r.condition_hindi}<span class="badge">${r.id}</span></h3>
       <button onclick="speak('${r.sanskrit.replace(/'/g,"")}')" style="padding:4px 8px;font-size:11px;background:#DAA520">🔊</button>
     </div>
     <div class="sanskrit">${r.sanskrit}<br><small style="color:#666">📖 ${r.source}</small></div>
     <p style="margin:6px 0;font-size:14px"><b>अर्थ:</b> ${r.hindi}</p>
     <div class="grid">
       <div><b style="color:green">✅</b> ${r.pathya.join(' • ')}</div>
       <div><b style="color:#c00">❌</b> ${r.apathya.join(' • ')}</div>
     </div>
   </div>`).join('') :
   `<div style="text-align:center;padding:30px;color:#999">"${q}" नहीं मिला<br><small>कोशिश: ज्वर, कास, श्वास, अजीर्ण</small></div>`;
}

function speak(t){ 
 if('speechSynthesis' in window){ 
   speechSynthesis.cancel(); 
   const u = new SpeechSynthesisUtterance(t); 
   u.lang='hi-IN'; u.rate=0.7; 
   speechSynthesis.speak(u);
 }
}

// Show examples on load
window.onload = () => {
 document.getElementById('results').innerHTML = `
 <p style="text-align:center;color:#666;padding:15px;font-size:13px">उदाहरण आज़माएं:</p>
 <div style="display:flex;flex-wrap:wrap;gap:6px;justify-content:center">
 ${['ज्वर','कास','श्वास','अजीर्ण','अतिसार','प्रमेह','कुष्ठ','वातरक्त'].map(w=>`<button onclick="document.getElementById('q').value='${w}';search()" style="background:#fff;color:#8B0000;border:1px solid #DAA520;padding:6px 12px;font-size:13px">${w}</button>`).join('')}
 </div>`;
};
</script>
